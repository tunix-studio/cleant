# Copy to `.env` (git-ignored) for a locally signed + notarized `pnpm tauri build`.
# In CI these are GitHub Actions Secrets instead — see .github/workflows/release.yml.

# "Developer ID Application: Your Name (TEAMID)"
APPLE_SIGNING_IDENTITY=

# Notarization (use an app-specific password, not your Apple ID password)
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Tauri updater signing (optional, only if you enable auto-updates):
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
